# Locally managed tunnel example (alternative to token install).
# Copy to /etc/cloudflared/config.yml and place credentials in /etc/cloudflared/
#
# tunnel: <TUNNEL_UUID>
# credentials-file: /etc/cloudflared/<TUNNEL_UUID>.json

ingress:
  - hostname: portal.yourdomain.com
    service: http://127.0.0.1:3000
  - service: http_status:404
