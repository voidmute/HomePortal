# Copy to android/keystore.properties (gitignored) for local signed release
# builds. In CI, the equivalent values are supplied via ANDROID_KEYSTORE_PATH /
# ANDROID_KEYSTORE_PASSWORD / ANDROID_KEY_ALIAS / ANDROID_KEY_PASSWORD env vars
# instead (see .github/workflows/build-apk.yml) — you don't need this file for CI.
storeFile=../keystore/release.keystore
storePassword=changeme
keyAlias=homeportal
keyPassword=changeme
