{
  "name": "family-home-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "npm run start --prefix cli",
    "predev": "node scripts/kura-compile.js",
    "prebuild": "node scripts/kura-compile.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "deps": "docker compose up postgres redis -d",
    "deps:down": "docker compose down",
    "deps:init": "docker compose exec -T postgres psql -U homelab -d homelab -f /dev/stdin < drizzle/migrations/0000_init.sql && docker compose exec -T postgres psql -U homelab -d homelab -f /dev/stdin < drizzle/migrations/0001_seed.sql",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "assets:generate": "node scripts/generate-mobile-assets.js",
    "assets:readme": "node scripts/generate-readme-assets.js && node scripts/generate-readme-features-html.js",
    "assets:all": "npm run assets:generate && npm run assets:readme"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "drizzle-orm": "^0.38.3",
    "framer-motion": "^11.15.0",
    "ioredis": "^5.4.2",
    "iron-session": "^8.0.4",
    "next": "14.2.35",
    "otplib": "^12.0.1",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-feather": "^2.0.10",
    "systeminformation": "^5.23.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "opentype.js": "^2.0.0",
    "postcss": "^8.4.49",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
